# ============================================================
# PharmaFind — Environment Variables Template
# Copy to .env (never commit .env to git)
# ============================================================

# ── Database ─────────────────────────────────────────────
DATABASE_URL="file:./prisma/pharmafind.db"

# ── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# In production: set to the exact frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── Next.js (client-accessible) ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# ── Search ───────────────────────────────────────────────
SEARCH_DEFAULT_RADIUS_KM=5
SEARCH_MAX_RADIUS_KM=50
TRGM_SIMILARITY_THRESHOLD=0.2

# ── AI (Gemini) ──────────────────────────────────────────
GEMINI_API_KEY="AIzaSyDn0og2WO-HsIYTLzyfxxaPBkha3EHjk0Q"
GEMINI_MODEL=gemini-3-flash-preview

# ── Production-only ──────────────────────────────────────
# SENTRY_DSN=https://...
# LOG_LEVEL=warn
# TRUST_PROXY=1
